{
  "name": "themegen",
  "version": "1.0.2",
  "description": "CLI Color / Theme Generator — generates platform-specific theme files from a canonical color schema",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "themegen": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "theme",
    "color",
    "cli",
    "generator",
    "monokai",
    "tango"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
