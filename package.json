{
  "name": "themegen",
  "version": "1.0.1",
  "description": "CLI Color / Theme Generator — generates platform-specific theme files from a canonical color schema",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "themegen": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
